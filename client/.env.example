# ==========================================
# Next.js Client Environment Variables
# Copy to client/.env for local Next.js client development.
# ==========================================

# 1. Database Connection URL (Neon PostgreSQL or Local DB)
# For local DB, use: postgresql://postgres:password123@localhost:5432/helpdesk_db?schema=public
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?schema=public"

# 2. Redis Connection URL
REDIS_URL="redis://localhost:6379"

# 3. RabbitMQ Broker URL
RABBITMQ_URL="amqp://localhost:5672"

# 4. JWT Authentication Signature Key
# Must match the server JWT_SECRET. Must be at least 32 characters long.
JWT_SECRET="dev-jwt-secret-key-at-least-32-chars-long-12345678"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-key-at-least-32-chars-long-12345678"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_ACCESS_MAX_AGE="900"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_MAX_AGE="604800"

# 5. Socket.IO Gateway Port
# Exposes websocket links. Defaults to port 3001.
SOCKET_PORT="3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# 6. AI LLM SDK API Keys (Gemini, Groq, Nvidia)
# Leave blank to fall back to simulated response strings.
GEMINI_API_KEY=""
GROQ_API_KEY=""
NVIDIA_API_KEY=""

# 7. Elasticsearch (Optional)
# Leave blank to fall back to Prisma SQL queries automatically.
ELASTICSEARCH_URL=""

# ==========================================
# Root Environment Template (Docker Compose & Local Setup)
# Copy this file to .env and configure keys for your local system.
# ==========================================

# 1. Databases and Infrastructure URLs (Used by Docker services)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/helpdesk_db?schema=public"
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://localhost:5672"

# 2. JWT Cryptographic Secrets
# Generates access tokens and handles cookie handshakes. Must be at least 32 characters long.
JWT_SECRET="dev-jwt-secret-key-at-least-32-chars-long-12345678"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-key-at-least-32-chars-long-12345678"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_ACCESS_MAX_AGE="900"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_MAX_AGE="604800"

# 3. AI Language Model API Keys (Required for AI Suggestion drafts)
# Retrieve keys from Google AI Studio / Groq Console / Nvidia NIM Dashboard
GEMINI_API_KEY=""
GROQ_API_KEY=""
NVIDIA_API_KEY=""

# 4. Elasticsearch Connection (Optional - Falls back to database SQL queries if empty)
ELASTICSEARCH_URL=""

# 5. Socket.IO Gateway Port (Defaults to port 3001)
SOCKET_PORT="3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# 6. Background Workers Configuration
# Set to false to bypass actual SMTP routing logic
SEND_EMAIL_ENABLED="true"

# 7. SMTP Server Credentials (Optional - Falls back to Ethereal accounts automatically if empty)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Helpdesk Support" <no-reply@helpdesk-saas.com>'

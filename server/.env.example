# ==========================================
# Socket.IO & RabbitMQ Worker Server Environment Variables
# Copy to server/.env for local backend development.
# ==========================================

# 1. Database Connection URL (Prisma auditing for webhooks/DLQ)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/helpdesk_db?schema=public"

# 2. Redis Connection URL
REDIS_URL="redis://localhost:6379"

# 3. RabbitMQ Broker Connection URL
RABBITMQ_URL="amqp://localhost:5672"

# 4. JWT Cryptographic Verification Key
# Must match the client JWT_SECRET. Must be at least 32 characters long.
JWT_SECRET="dev-jwt-secret-key-at-least-32-chars-long-12345678"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-key-at-least-32-chars-long-12345678"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_ACCESS_MAX_AGE="900"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_MAX_AGE="604800"

# 5. Socket.IO Port Definition
SOCKET_PORT="3001"

# 6. Email Mailer Settings
SEND_EMAIL_ENABLED="true"

# SMTP Mail Server Credentials (Optional - Falls back to Ethereal developer sandbox if empty)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Helpdesk Support" <no-reply@helpdesk-saas.com>'

# 7. Elasticsearch Connection (Optional)
ELASTICSEARCH_URL=""

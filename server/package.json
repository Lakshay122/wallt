{
  "name": "helpdesk-server",
  "version": "1.0.0",
  "description": "Socket.IO real-time server and RabbitMQ background workers for Multi-Tenant Helpdesk",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "build": "tsc",
    "start": "node dist/workers/runAll.js & node dist/index.js",
    "worker": "ts-node workers/runAll.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "7.13.0",
    "@prisma/client": "^5.14.0",
    "amqplib": "^0.10.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "^6.2.3",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.15",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "^4.0.0"
  }
}
